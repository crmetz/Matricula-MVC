@model List<Matriculas.Models.ViewModels.RankingItem>

<table class="table table-striped table-bordered">
    <thead>
        <tr><th>#</th><th>Nome</th><th class="text-end">Matrículas</th></tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="3" class="text-center text-muted">Sem dados.</td></tr>
        }
        @for (var i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>@(i + 1)</td>
                <td>@Model[i].Nome</td>
                <td class="text-end">@Model[i].Total.ToString("N0")</td>
            </tr>
        }
    </tbody>
</table>

@model Matriculas.Models.ViewModels.LinhaDoTempoViewModel
@using Matriculas.Models
@{
    ViewData["Title"] = "Linha do tempo de um curso";
}

<h2>Linha do tempo de um curso</h2>
<p class="text-muted">Evolução do número de matriculados ano a ano.</p>

<form method="get" class="row row-cols-auto g-2 align-items-end mb-3">
    <div class="col">
        <label class="form-label" for="nomeCurso">Curso</label>
        <select id="nomeCurso" name="nomeCurso" class="form-select">
            <option value="">— selecione um curso —</option>
            @foreach (var curso in Model.CursosDisponiveis)
            {
                <option value="@curso" selected="@(curso == Model.NomeCurso)">@curso</option>
            }
        </select>
    </div>
    <div class="col">
        <label class="form-label" for="modalidade">Modalidade</label>
        <select id="modalidade" name="modalidade" class="form-select">
            <option value="@Modalidades.Todos" selected="@(Model.Modalidade == Modalidades.Todos)">Todos</option>
            <option value="@Modalidades.Presencial" selected="@(Model.Modalidade == Modalidades.Presencial)">Presencial</option>
            <option value="@Modalidades.EaD" selected="@(Model.Modalidade == Modalidades.EaD)">EaD</option>
        </select>
    </div>
    <div class="col">
        <button type="submit" class="btn btn-primary">Gerar</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.NomeCurso))
{
    <h4>@Model.NomeCurso <small class="text-muted">(@Model.Modalidade)</small></h4>
    @if (Model.Serie.Any())
    {
        <table class="table table-striped table-bordered w-auto">
            <thead>
                <tr><th>Ano</th><th class="text-end">Matriculados</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Serie)
                {
                    <tr>
                        <td>@item.Ano</td>
                        <td class="text-end">@item.Total.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Nenhuma matrícula encontrada para esse curso/modalidade.</p>
    }
}
